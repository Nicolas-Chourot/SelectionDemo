
@{ ViewBag.Title = "Edit"; }

<h2>Sélection de couleurs</h2>
<hr />

@using (Html.BeginForm())
{
    @Helper.SelectionLists("selectedColorsId", (SelectList)ViewBag.SelectedColors, (SelectList)ViewBag.AllColors)

    <br />
    <input type="submit" value="Soumettre" class="form-control" />
}

@section Scripts {
    <script>
        $(() => {
            $("option").each(function (index, option) {
                let hex = option.text.split(" ")[0];
                $(this).attr("style", `color:${getContrast(hex)}; background-color:${hex}`);
            })
        })
        
    </script>
}